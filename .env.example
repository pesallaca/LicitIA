# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=cambia-este-secreto-en-produccion

# LLM Provider: 'ollama' | 'openai'
LLM_PROVIDER=ollama

# Ollama (desarrollo)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# OpenAI (producción)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Database
DB_PATH=./server/data/licitia.db
