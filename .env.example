# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=cambia-este-secreto-en-produccion

# Operación del SaaS
# true = análisis desactivado temporalmente (503). Por defecto: activo.
MAINTENANCE_MODE=false
# false = cierra el registro self-service. Por defecto: abierto.
ALLOW_REGISTRATION=true
# Origen del frontend en producción si se sirve desde OTRO dominio (CORS).
# Vacío = solo mismo origen (recomendado: el server ya sirve el frontend).
FRONTEND_ORIGIN=
# Máximo de caracteres del pliego que se envían al modelo.
MAX_TENDER_CHARS=48000
# Días de validez de los enlaces de informes compartidos.
SHARE_EXPIRY_DAYS=30

# LLM Provider: 'ollama' | 'openai'
LLM_PROVIDER=ollama

# Ollama (desarrollo)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# OpenAI o cualquier API compatible (Featherless, Groq, Together...)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Cambia la URL para usar otro proveedor compatible con OpenAI:
#   Featherless: https://api.featherless.ai/v1   Groq: https://api.groq.com/openai/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Database
DB_PATH=./server/data/licitia.db
